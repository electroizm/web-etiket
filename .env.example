DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
# Production'da: https://web-etiket.onrender.com (virgülle birden fazla)
DJANGO_CSRF_TRUSTED_ORIGINS=

# Supabase Project Settings → API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Backend'de access_token doğrulamak için (ikisinden BİRİ yeterli) ---

# (Yeni asimetrik şema) Supabase Project Settings → API → JWT Keys → Public Key (JWK)
# Tek satır JSON. Örn: {"kty":"EC","crv":"P-256","alg":"ES256","x":"...","y":"...","kid":"...","key_ops":["verify"]}
SUPABASE_JWT_JWK=

# (Eski projeler) Project Settings → API → JWT Settings → JWT Secret (HS256 shared secret)
SUPABASE_JWT_SECRET=

# --- Scraper (catalog/services/scraper.py) ---
# Supabase Postgres direct connection. Project Settings → Database → Connection string (URI, Session mode)
# Aldığın URL'in başına 'postgresql+psycopg2://' ekle.
# Örnek: postgresql+psycopg2://postgres:SIFREN@db.<ref>.supabase.co:5432/postgres
DATABASE_URL=

SCRAPER_CONCURRENCY=2
SCRAPER_RATE_DELAY_MIN=1.0
SCRAPER_RATE_DELAY_MAX=3.0
# Virgülle ayrılmış kategori adları — bu kategorilerdeki ürünler DB'ye yazılmaz.
SCRAPER_SKIP_KATEGORILER=Doğtaş Home

# --- Telegram bildirimi (scraper özeti; boşsa devre dışı) ---
# @BotFather → /newbot → token. Botla bir kez konuş, sonra chat id'ni gir.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- WhatsApp bildirimi (CallMeBot; boşsa devre dışı) ---
# Her alıcı bir kez: +34 644 81 58 78'i rehbere ekle, WhatsApp'tan
# "I allow callmebot to send me messages" yaz, gelen apikey'i kullan.
# Format: telefon:apikey çiftleri, virgülle ayrık.
# Örn: WHATSAPP_ALICILAR=+905551112233:123456,+905554445566:654321
WHATSAPP_ALICILAR=

# --- Sentry hata izleme (boşsa devre dışı) ---
# sentry.io → proje oluştur → DSN'i yapıştır.
SENTRY_DSN=
